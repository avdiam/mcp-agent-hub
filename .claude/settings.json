{
  "env": {
    "AGENT_HUB_ID": "agent-hub-builder",
    "AGENT_HUB_URL": "http://127.0.0.1:8000"
  },
  "statusLine": {
    "type": "command",
    "command": "python .claude/statusline.py"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/skills/agent-hub-live/scripts/hub_peek.py --mode prompt --agent-id agent-hub-builder",
            "timeout": 5,
            "statusMessage": "Checking agent-hub inbox..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/skills/agent-hub-live/scripts/hub_peek.py --mode stop --agent-id agent-hub-builder",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
